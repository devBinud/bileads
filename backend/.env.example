# ─────────────────────────────────────────────────────────────
# Firebase Realtime Database Secret
# ─────────────────────────────────────────────────────────────
# How to get it (takes 30 seconds):
# 1. Go to https://console.firebase.google.com
# 2. Open your project: leadradar-bc285
# 3. Click the gear icon → Project Settings
# 4. Click the "Service Accounts" tab
# 5. Scroll down to "Database secrets" → click "Show" → copy it
#    (If none exists, click "Add secret")
#
FIREBASE_DB_SECRET=your_database_secret_here

# Server port (leave as 3001 unless something else is using it)
PORT=3001
